# Base URL of the backend API, called both server-side (NextAuth callbacks) and
# client-side (exposed via NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical URL of this frontend deployment. NextAuth uses this to build callback
# URLs and to decide whether cookies should be marked secure (https).
NEXTAUTH_URL=http://localhost:3000
# Secret NextAuth uses to encrypt session JWTs. Rotating this logs out every user.
NEXTAUTH_SECRET=change-me-to-a-random-64-char-string

# Google OAuth client credentials. Leave both blank to disable Google sign-in
# entirely (the provider is only registered when both are present).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match backend INTERNAL_API_SECRET exactly.
INTERNAL_API_SECRET=change-me-shared-with-frontend-nextauth
