# Deployment environment: development | test | production. Gates behavior like
# whether Sentry/production-only checks are active.
ENV=development

# Async SQLAlchemy connection string used by the running FastAPI app (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://wattwise:wattwise@localhost:5432/wattwise
# Sync connection string used only by Alembic migrations (psycopg driver).
SYNC_DATABASE_URL=postgresql+psycopg://wattwise:wattwise@localhost:5432/wattwise

# HMAC signing key for access/refresh JWTs. Rotating this logs out every user.
JWT_SECRET=change-me-to-a-random-64-char-string
# Shared secret the frontend's NextAuth server calls back with on /auth/oauth/exchange.
# Must be identical to the frontend's INTERNAL_API_SECRET or Google sign-in returns 403.
INTERNAL_API_SECRET=change-me-shared-with-frontend-nextauth
# Required X-Metrics-Token header value to read /metrics. Keeps the Prometheus
# scrape endpoint from being publicly readable.
METRICS_TOKEN=change-me-required-as-x-metrics-token-header-to-read-metrics
# JWT signing algorithm. HS256 (symmetric) — keep in sync with app/core/security.py.
JWT_ALGORITHM=HS256
# How long an access token stays valid before the frontend must refresh it.
ACCESS_TOKEN_EXPIRE_MINUTES=30
# How long a refresh token stays valid before the user must log in again.
REFRESH_TOKEN_EXPIRE_DAYS=30

# JSON list of origins allowed by CORS. Must include the deployed frontend's URL.
CORS_ORIGINS=["http://localhost:3000"]

# Sentry DSN for error tracking. Leave blank to disable Sentry entirely.
SENTRY_DSN=

# Default slowapi rate limit string for endpoints that don't declare their own.
RATE_LIMIT_DEFAULT=60/minute
# Python logging level for structlog's underlying stdlib handler.
LOG_LEVEL=INFO
