# --- Node / Next.js (frontend) ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/coverage/
frontend/playwright-report/
frontend/test-results/
frontend/next-env.d.ts

# --- Python / FastAPI (backend) ---
backend/.venv/
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/*.egg-info/
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/htmlcov/
backend/.coverage
backend/.env

# --- ML ---
ml/**/__pycache__/
ml/.venv/
ml/.pytest_cache/
ml/.mypy_cache/
ml/.ruff_cache/
ml/.coverage
ml/data/raw/
ml/data/processed/
ml/mlruns/
ml/evaluation/reports/*.json

# Model artifacts ARE committed (see docs/ML.md) — small (<50MB total), keeps
# CI and deployment deterministic without needing to retrain on every deploy.

# --- Shared libs (libs/wattwise_tariffs, libs/wattwise_climate) ---
libs/**/__pycache__/
libs/**/*.egg-info/
libs/**/.pytest_cache/
libs/**/.mypy_cache/
libs/**/.ruff_cache/
libs/**/.coverage

# --- Env / secrets ---
.env
.env.local
*.pem
*.key

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/

# --- Docker ---
*.pid

# --- Misc ---
*.log
.turbo/
